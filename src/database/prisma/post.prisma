model Post {
  id         Int       @id @default(autoincrement())
  uuid       String    @default(cuid())
  title      String
  content    String
  categoryId Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  category   Category  @relation(fields: [categoryId], references: [id])
  tags       Tag[]     @relation("PostToTag")
}
